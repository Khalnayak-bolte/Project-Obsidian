# =============================================================================
# Obsidian Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# In production, all variables are injected via AWS Secrets Manager / SSM.
# =============================================================================

# ─── App ──────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# URL of the deployed frontend (used for CORS and invite email links)
FRONTEND_URL=http://localhost:5173

# Internal JWT secret for server-to-server token signing (32+ char random string)
INTERNAL_JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# ─── AWS Core ─────────────────────────────────────────────────────────────────

AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# Only required for local development — Lambda uses its IAM role in prod
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ─── Firebase ─────────────────────────────────────────────────────────────────

# Full JSON of your Firebase service account key (minified, single line)
# Generate at: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"obsidian-dev","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@obsidian-dev.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firebase Realtime Database URL (only needed if using RTDB alongside Firestore)
FIREBASE_DATABASE_URL=https://obsidian-dev-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Storage bucket (without gs:// prefix)
FIREBASE_STORAGE_BUCKET=obsidian-dev.appspot.com

# ─── AWS S3 ───────────────────────────────────────────────────────────────────

# S3 bucket for workspace file storage
AWS_S3_BUCKET=obsidian-files-dev

# CloudFront CDN base URL for serving files (no trailing slash)
# Leave empty to serve directly from S3 signed URLs
AWS_CLOUDFRONT_URL=https://d1234abcd.cloudfront.net

# ─── Amazon Chime SDK ─────────────────────────────────────────────────────────

# Media region for Chime meetings — closest to your users
# ap-southeast-1 (Singapore) is recommended for India
CHIME_MEDIA_REGION=ap-southeast-1
CHIME_REGION=ap-southeast-1

# ─── AWS EventBridge ──────────────────────────────────────────────────────────

# Custom event bus name (created by serverless.yml on first deploy)
AWS_EVENTBRIDGE_BUS=obsidian-events-dev

# ─── AWS SQS ─────────────────────────────────────────────────────────────────

# Full queue URLs (output by CloudFormation after first deploy)
AWS_SQS_NOTIFICATION_QUEUE=https://sqs.ap-south-1.amazonaws.com/123456789012/obsidian-notification-dev.fifo
AWS_SQS_EMAIL_QUEUE=https://sqs.ap-south-1.amazonaws.com/123456789012/obsidian-email-dev.fifo
AWS_SQS_CLEANUP_QUEUE=https://sqs.ap-south-1.amazonaws.com/123456789012/obsidian-cleanup-dev

# Full queue ARNs (required by serverless.yml SQS event sources)
AWS_SQS_NOTIFICATION_QUEUE_ARN=arn:aws:sqs:ap-south-1:123456789012:obsidian-notification-dev.fifo
AWS_SQS_EMAIL_QUEUE_ARN=arn:aws:sqs:ap-south-1:123456789012:obsidian-email-dev.fifo
AWS_SQS_CLEANUP_QUEUE_ARN=arn:aws:sqs:ap-south-1:123456789012:obsidian-cleanup-dev

# ─── AWS SES ──────────────────────────────────────────────────────────────────

# Verified sender email address in SES
# Must be verified in SES before use: aws ses verify-email-identity --email-address
AWS_SES_FROM_EMAIL=noreply@obsidian.app

# ─── Razorpay ─────────────────────────────────────────────────────────────────

# Razorpay API credentials
# Test keys start with rzp_test_, live keys with rzp_live_
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Webhook secret — set in Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Razorpay Plan IDs — create these in Razorpay Dashboard → Subscriptions → Plans
# Gold tier
RAZORPAY_PLAN_GOLD_MONTHLY=plan_XXXXXXXXXXXXXXXX
RAZORPAY_PLAN_GOLD_YEARLY=plan_XXXXXXXXXXXXXXXX

# Premium tier
RAZORPAY_PLAN_PREMIUM_MONTHLY=plan_XXXXXXXXXXXXXXXX
RAZORPAY_PLAN_PREMIUM_YEARLY=plan_XXXXXXXXXXXXXXXX

# Deluxe tier
RAZORPAY_PLAN_DELUXE_MONTHLY=plan_XXXXXXXXXXXXXXXX
RAZORPAY_PLAN_DELUXE_YEARLY=plan_XXXXXXXXXXXXXXXX

# =============================================================================
# Local Development Notes
# =============================================================================
#
# 1. Firebase Emulator
#    Run: firebase emulators:start
#    Set FIRESTORE_EMULATOR_HOST=localhost:8080
#    Set FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
#
# 2. Serverless Offline
#    Run: npx serverless offline
#    API will be available at http://localhost:4000
#
# 3. AWS credentials for local dev
#    Configure via: aws configure --profile obsidian-dev
#    Or set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above
#
# 4. SQS local (optional)
#    Use ElasticMQ or LocalStack: docker run -p 9324:9324 softwaremill/elasticmq
#    Update queue URLs to: http://localhost:9324/queue/...
#
# 5. Razorpay test mode
#    Use test card: 4111 1111 1111 1111, any future expiry, any CVV
#    Webhooks: use ngrok to expose localhost — ngrok http 4000
#
# =============================================================================
